PORT=4000
DATABASE_URL=postgresql://postgres.your-project-ref:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
GITHUB_TOKEN=your_github_personal_access_token_here
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-flash-lite-latest
LLM_PROVIDER=gemini
LLM_MAX_FAILURES=3
LLM_COOLDOWN_MS=300000
GITINGEST_PYTHON_BIN=python
CACHE_TTL_SECONDS=3600
MAX_COMMITS_TO_FETCH=1000
MAX_DETAILED_COMMITS=50
MIN_COMMITS_REQUIRED=10
FRONTEND_URL=http://localhost:3000
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Email verification (Resend)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
AUTH_JWT_SECRET=replace_with_strong_random_secret
AUTH_JWT_EXPIRES_IN=7d
AUTH_VERIFY_EXPIRES_IN=24h
BACKEND_URL=http://localhost:4000
